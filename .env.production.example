# Production environment variables — add these in
# Vercel → Project → Settings → Environment Variables (scope: Production).
# NEVER commit real values. See DEPLOY_TODAY.md for the full launch runbook.

# Supabase Postgres (REQUIRED for durable history — use the pooled
# "Transaction" connection string from Supabase → Connect)
DATABASE_URL=

# Apify (console.apify.com → Settings → API & Integrations)
APIFY_TOKEN=

# Verified actors for this campaign (tested live 2026-06-10)
APIFY_TIKTOK_ACTOR_ID=GdWCkxBtKWOsKjdch
APIFY_INSTAGRAM_ACTOR_ID=xMc5Ga1oCONPmWJIa
APIFY_FACEBOOK_ACTOR_ID=KoJrdxJCTtpon81KY
APIFY_YOUTUBE_ACTOR_ID=WT1BVWatl2aHVeFEH

# Optional — when set, YouTube switches to the official Data API (adds comments)
YOUTUBE_API_KEY=

# Protects /api/cron/refresh. Generate: openssl rand -hex 24
# Vercel Cron automatically sends it as "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=

# REQUIRED before sharing the URL — gates /admin
ADMIN_PASSWORD=

NEXT_PUBLIC_APP_NAME=Wachter Creator Campaign Dashboard
