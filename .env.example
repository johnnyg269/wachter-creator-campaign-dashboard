# Copy to .env.local for local development. NEVER commit real values.
# In production, add these in Vercel → Project → Settings → Environment Variables.

NEXT_PUBLIC_APP_NAME="Wachter Creator Campaign Dashboard"

# ── Apify (server-side only) ────────────────────────────────────────────────
# Get your token at https://console.apify.com/account#/integrations
APIFY_TOKEN=

# Actor IDs — find/test them in /admin → Apify Setup, then persist them here
# (locally) and in Vercel env vars (production). Format: "username~actor-name"
# or the raw actor ID string (e.g. "PE8EVAh0QG4mH6cLP").
APIFY_TIKTOK_ACTOR_ID=
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_FACEBOOK_ACTOR_ID=
APIFY_YOUTUBE_ACTOR_ID=

# ── YouTube official API (preferred for YouTube when present) ───────────────
# https://console.cloud.google.com → enable "YouTube Data API v3" → API key
YOUTUBE_API_KEY=

# ── Database ────────────────────────────────────────────────────────────────
# Supabase Postgres connection string (Transaction pooler URL recommended on
# Vercel). When empty, the app falls back to a local JSON file store —
# fine for local dev, NOT durable on Vercel.
DATABASE_URL=

# ── App security ────────────────────────────────────────────────────────────
# Required to gate /admin. If unset, /admin is open (local dev only).
ADMIN_PASSWORD=

# Shared secret for /api/cron/refresh. Vercel Cron sends it automatically as
# "Authorization: Bearer $CRON_SECRET" when this env var is set.
# Generate one: `openssl rand -hex 24`
CRON_SECRET=

# ── Optional future official-API integrations ───────────────────────────────
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── Local development only ──────────────────────────────────────────────────
# "1" enables clearly-labeled demo data. Never enable in production.
MOCK_DATA=
