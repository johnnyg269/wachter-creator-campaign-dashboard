# Copy to .env.local for local development. NEVER commit real values.
# In production, add these in Vercel → Project → Settings → Environment Variables.

NEXT_PUBLIC_APP_NAME="Wachter Creator Campaign Dashboard"

# ── Apify (server-side only) ────────────────────────────────────────────────
# Get your token at https://console.apify.com/account#/integrations
APIFY_TOKEN=

# Actor IDs — find/test them in /admin → Apify Setup, then persist them here
# (locally) and in Vercel env vars (production). Format: "username~actor-name"
# or the raw actor ID string (e.g. "PE8EVAh0QG4mH6cLP").
APIFY_TIKTOK_ACTOR_ID=
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_FACEBOOK_ACTOR_ID=
APIFY_YOUTUBE_ACTOR_ID=

# Optional backup actors — run only when the primary leaves gaps (missing
# views, video not returned). Test in /admin → Apify Setup before relying on.
APIFY_TIKTOK_BACKUP_ACTOR_ID=
APIFY_INSTAGRAM_BACKUP_ACTOR_ID=
APIFY_FACEBOOK_BACKUP_ACTOR_ID=
APIFY_YOUTUBE_BACKUP_ACTOR_ID=

# ── SocialCrawl (primary metrics for TikTok/Instagram/Facebook) ─────────────
# Server-side only — never NEXT_PUBLIC, never client-exposed. SocialCrawl returns
# the PUBLIC Facebook Reel plays Apify undercounts, at TikTok/Instagram parity.
# When enabled it is the primary provider; Apify stays as fallback only. YouTube
# always uses the official Data API. With all three unset, the app stays on Apify
# (no behavior change) — set these in Vercel Production to activate SocialCrawl.
SOCIALCRAWL_API_KEY=
SOCIALCRAWL_METRICS_ENABLED=false
NON_YOUTUBE_METRICS_PROVIDER=apify     # apify | socialcrawl
FACEBOOK_METRICS_PROVIDER=apify        # apify | socialcrawl (defaults to NON_YOUTUBE_METRICS_PROVIDER)
SOCIALCRAWL_DAILY_CREDIT_CAP=300       # scheduled refreshes stop when reached

# ── Option B refresh tiers (Phase 2) ─────────────────────────────────────────
# Campaign assignment + age decide refresh cadence. MTL videos ≤ HOT_VIDEO_AGE_DAYS
# old are "hot" (15 min); older MTL is "warm" (30 min); Bootcamp videos refresh
# once per day regardless of age; removed/excluded videos never refresh. The
# per-post catch-up lane for videos beyond the ~10-item profile window is bounded
# by SOCIALCRAWL_DAILY_CREDIT_CAP (warm MTL before the Bootcamp batch).
HOT_VIDEO_AGE_DAYS=7
HOT_REFRESH_INTERVAL_MINUTES=15
WARM_REFRESH_INTERVAL_MINUTES=30
BOOTCAMP_REFRESH_INTERVAL_HOURS=24
# Comment/detail pulls are limited to hot MTL by default — flip these on to also
# pull Bootcamp / cold-video comments (extra credits).
BOOTCAMP_COMMENT_DETAIL_ENABLED=false
COLD_COMMENT_DETAIL_ENABLED=false

# ── Bootcamp import (Phase 2) ─────────────────────────────────────────────────
# Required Bootcamp start date + first-video anchors (admin can override per run).
# SocialCrawl can't crawl the TT/IG/FB back-catalog (profile = ~10 most recent,
# no pagination) — paste those URLs in /admin → Bootcamp Import. YouTube Shorts
# auto-enumerate from the start date (free Data API). Anchors are pre-filled in code.
BOOTCAMP_START_DATE=2026-04-11
# BOOTCAMP_ANCHOR_TIKTOK=
# BOOTCAMP_ANCHOR_INSTAGRAM=
# BOOTCAMP_ANCHOR_FACEBOOK=
# BOOTCAMP_ANCHOR_YOUTUBE=

# Refresh cadence / quiet hours (ET). Defaults: 15-min metrics when SocialCrawl
# is on (60-min on Apify), quiet 00:00–07:00 ET, comment detail twice/active-day.
METRICS_REFRESH_INTERVAL_MINUTES=15
QUIET_HOURS_START_ET=00:00
QUIET_HOURS_END_ET=07:00
COMMENT_DETAIL_PULLS_PER_DAY=2
COMMENT_DETAIL_PULL_1_ET=12:00
COMMENT_DETAIL_PULL_2_ET=18:00
# Discovery (finding NEW campaign posts on the known creator profiles): runs
# every N active hours; auto-adds eligible posts published within the lookback
# window, older-but-eligible posts go to the admin "Possible new content" queue.
DISCOVERY_REFRESH_INTERVAL_HOURS=2
DISCOVERY_LOOKBACK_HOURS=72

# ── Campaign ────────────────────────────────────────────────────────────────
# Campaign-start floor (ET, YYYY-MM-DD). Content published before this — and any
# record with an invalid/epoch date — is excluded from active campaign totals.
# Adjust if the campaign start changes. Default: 2026-06-08.
CAMPAIGN_START_DATE_ET=2026-06-08

# ── YouTube official API (preferred for YouTube when present) ───────────────
# https://console.cloud.google.com → enable "YouTube Data API v3" → API key
YOUTUBE_API_KEY=

# ── Database ────────────────────────────────────────────────────────────────
# Supabase Postgres connection string (Transaction pooler URL recommended on
# Vercel). When empty, the app falls back to a local JSON file store —
# fine for local dev, NOT durable on Vercel.
DATABASE_URL=

# ── App security ────────────────────────────────────────────────────────────
# Required to gate /admin. If unset, /admin is open (local dev only).
ADMIN_PASSWORD=

# Shared secret for /api/cron/refresh. Vercel Cron sends it automatically as
# "Authorization: Bearer $CRON_SECRET" when this env var is set.
# Generate one: `openssl rand -hex 24`
CRON_SECRET=

# ── Optional future official-API integrations ───────────────────────────────
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── Refresh cost-control policy (all optional; safe defaults shown) ──────────
# Views are primary + cheap; comment detail is secondary + expensive. The
# external scheduler pings every ~30 min and THIS policy decides what runs.
# Metrics cadence (minutes):
REFRESH_FULL_INTERVAL_MINUTES=60         # full metrics refresh cadence
ENABLE_LIGHT_REFRESH=true                # hot-video tier between fulls (default on)
REFRESH_LIGHT_INTERVAL_MINUTES=30        # hot-video tier cadence
ENABLE_DISCOVERY_REFRESH=true
REFRESH_DISCOVERY_INTERVAL_MINUTES=720   # new-post hunting ~twice/day
# Comment detail (full text) — pulled once per day; metrics-only refreshes skip
# all comment add-ons. Comment COUNTS still update every metrics refresh.
ENABLE_COMMENT_REFRESH=true
COMMENT_DETAIL_REFRESH_INTERVAL_HOURS=24
COMMENT_DETAIL_REFRESH_HOUR=9            # local hour the daily pull runs at/after
COMMENT_DETAIL_REFRESH_TIMEZONE=America/New_York
# Instagram share-count add-on — off by default (stored data showed it null).
ENABLE_INSTAGRAM_SHARES=
# Apify spend kill-switch. SocialCrawl is primary, so Apify is OFF by default —
# it only runs as an emergency fallback when ENABLED *and* both caps are > 0.
# Leave disabled / caps 0 to guarantee no Apify spend (SocialCrawl failure then
# preserves last-known-good). Set ENABLED=true + caps>0 to re-allow fallback.
APIFY_FALLBACK_ENABLED=false
APIFY_DAILY_SPEND_CAP_USD=0
APIFY_DAILY_RUN_CAP=0
# Budget + quiet hours (the cap and quiet window always win over cadence):
APIFY_DAILY_BUDGET_TARGET_USD=2
APIFY_DAILY_HARD_CAP_USD=3
APIFY_EST_COST_PER_RUN_USD=0.02
REFRESH_QUIET_HOURS_ENABLED=true
REFRESH_QUIET_HOURS_START=0
REFRESH_QUIET_HOURS_END=6
REFRESH_QUIET_HOURS_TIMEZONE=America/New_York

# ── Local development only ──────────────────────────────────────────────────
# "1" enables clearly-labeled demo data. Never enable in production.
MOCK_DATA=
